# Copy to .env.local (or let `npx convex dev` create/update it).
#
# Local dev layout (anonymous / `npx convex dev`):
#   - Expo web UI:     http://localhost:8081  (Metro; path e.g. /login)
#   - Convex WebSocket/site: convex dev often picks 3212/3213 *or* 3210/3211.
#       `app.config.js` probes open loopback ports so stale README ports don't
#       break login ("Failed to fetch"); still prefer values from `convex dev`.
# Keep `npx convex dev` running while using the app, or use: npm run dev
#
# Convex deployment env (not in this file — set via CLI):
#   npx convex env set SITE_URL http://localhost:8081
#   npx convex env set BETTER_AUTH_SECRET "$(openssl rand -base64 32)"
# SITE_URL must match the browser origin (scheme + host + port) of the Expo web app.

EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
